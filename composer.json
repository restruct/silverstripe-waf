{
    "name": "restruct/silverstripe-waf",
    "description": "PHP-level Web Application Firewall for Silverstripe - blocks vulnerability scanners, bad bots, and malicious IPs",
    "type": "silverstripe-vendormodule",
    "license": "MIT",
    "keywords": [
        "silverstripe",
        "security",
        "waf",
        "firewall",
        "ip-blocking",
        "rate-limiting"
    ],
    "authors": [
        {
            "name": "Restruct",
            "email": "dev@restruct.nl"
        }
    ],
    "require": {
        "php": "^8.1",
        "silverstripe/framework": "^5.0 || ^6.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Restruct\\SilverStripe\\Waf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Restruct\\SilverStripe\\Waf\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "installer-name": "waf"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
